# ─── Banco de dados (Neon PostgreSQL em prod, SQLite permitido em dev) ──
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Autenticação de sessão (iron-session) ───────────────────────────────
# Gerar com: openssl rand -hex 32
SESSION_SECRET=

# ─── Bot WhatsApp (integração com arena-wa-infra) ────────────────────────
# Compartilhado com n8n. Gerar com: openssl rand -hex 32
# Obrigatório em produção para endpoint POST /api/bot/quote validar HMAC.
BOT_HMAC_SECRET=

# ─── Stripe (billing de subscription do Seller) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Sentry (observabilidade opcional) ───────────────────────────────────
SENTRY_DSN=
