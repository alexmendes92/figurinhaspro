generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Seller {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  shopName  String
  shopSlug        String   @unique
  logo            String?
  shopDescription String?
  businessHours   String?
  paymentMethods  String?
  plan            String   @default("FREE")

  // Stripe billing
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Onboarding
  onboardingStep Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory          Inventory[]
  orders             Order[]
  priceRules         PriceRule[]
  sectionPriceRules  SectionPriceRule[]
  quantityTiers      QuantityTier[]
  subscriptionEvents SubscriptionEvent[]
  customAlbums       CustomAlbum[]
}

model SubscriptionEvent {
  id            String   @id @default(cuid())
  sellerId      String
  seller        Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type          String
  stripeEventId String   @unique
  data          String
  createdAt     DateTime @default(now())
}

model Inventory {
  id          String   @id @default(cuid())
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  albumSlug   String
  stickerCode String
  quantity    Int      @default(0)
  customPrice Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sellerId, albumSlug, stickerCode])
  @@index([sellerId, albumSlug])
}

model PriceRule {
  id          String  @id @default(cuid())
  sellerId    String
  seller      Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  albumSlug   String?
  stickerType String
  price       Float

  @@unique([sellerId, albumSlug, stickerType])
}

model Order {
  id            String   @id @default(cuid())
  sellerId      String
  seller        Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  customerEmail String?
  status        String   @default("QUOTE")
  totalPrice    Float
  channel       String   @default("SYSTEM")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  albumSlug   String
  stickerCode String
  stickerName String
  quantity    Int
  unitPrice   Float
}

model SectionPriceRule {
  id          String @id @default(cuid())
  sellerId    String
  seller      Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  albumSlug   String
  sectionName String
  adjustType  String @default("FLAT") // "FLAT" = preço absoluto | "OFFSET" = +/- sobre preço base
  value       Float

  @@unique([sellerId, albumSlug, sectionName])
  @@index([sellerId, albumSlug])
}

model QuantityTier {
  id          String @id @default(cuid())
  sellerId    String
  seller      Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  albumSlug   String
  minQuantity Int
  discount    Float  // percentual de desconto (ex: 10 = 10% off)

  @@unique([sellerId, albumSlug, minQuantity])
  @@index([sellerId, albumSlug])
}

model CustomAlbum {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  year      String   @default("")
  stickers  String   // JSON: [{code, name, type}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sellerId, slug])
  @@index([sellerId])
}
